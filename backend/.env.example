# AlgoVision Backend - Environment Variables
# Copy this file to .env and fill in your values.

# Server
PORT=5000

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Piston code execution
# Public API: https://emkc.org/api/v2/piston
# Self-hosted: http://localhost:2000/api/v2/piston
PISTON_API_URL=http://localhost:2000/api/v2/piston
PISTON_API_KEY=

# Keep this false in normal use so untrusted code is never executed on the app server.
ALLOW_LOCAL_CODE_EXECUTION=false

# Gemini / OpenAI are used by the tutor, analysis, and optional AI simulation fallback.
GEMINI_API_KEY=AIzaSyAzMkOpiYhGzTOK_6igk7IovbixSgBwMPo
OPENAI_API_KEY=

# Firebase (optional - static data is used as a fallback if not set)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_PROJECT_ID=your-firebase-project-id
